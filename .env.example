# ============================================================
# 환경변수 예시 (.env.example)
# ------------------------------------------------------------
# 현 프로젝트는 정적 HTML/JS 로 구성되어 있어 빌드 시점에 본 파일을
# 직접 읽어 들이지 않는다. 본 파일은 다음 용도로만 사용한다:
#
#   1) 운영자가 Cloudflare Pages 콘솔의 "Environment variables" 화면에
#      어떤 키를 등록해야 하는지 안내한다.
#   2) 향후 Pages Functions (server-side) 도입 시 동일 키를 그대로
#      참조할 수 있도록 표준 이름을 고정한다.
#   3) index.html 의 <meta name="cf-access-team-domain"> 값과
#      _redirects 의 /logout 대상 도메인이 본 변수와 동일해야 한다는
#      운영 규칙을 명문화한다.
# ============================================================

# ----- Cloudflare Access -----
# Zero Trust 팀 슬러그. 발급 도메인은
#   https://${CF_ACCESS_TEAM_DOMAIN}.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=energytf

# Access Application Audience (AUD) 태그.
# Zero Trust → Access → Applications → 해당 앱 → Overview 에서 복사.
# Pages Functions 에서 JWT 검증 시 사용 (현 단계에서는 미사용).
CF_ACCESS_AUD=

# ----- (옵션) 추후 SharePoint 전환 대비 -----
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_SITE_ID=
# SHAREPOINT_KPI_LIST_ID=
# SHAREPOINT_PHOTOS_DRIVE_ID=
